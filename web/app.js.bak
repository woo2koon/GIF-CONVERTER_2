    // Split Button logic
    convertSplitBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const checkedCount = document.querySelectorAll('.lib-checkbox:checked').length;
        if (checkedCount < 2) return;
        batchMenu.classList.toggle('hidden');
